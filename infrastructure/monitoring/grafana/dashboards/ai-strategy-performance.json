{
  "id": null,
  "title": "AI Strategy Performance",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "type": "stat",
      "title": "Active Backtest Runs",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(ai_backtest_status) - sum(ai_backtest_status{status=\"completed\"})",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 0
      }
    },
    {
      "type": "timeseries",
      "title": "Backtest PnL (per run)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "ai_backtest_total_pnl",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      }
    },
    {
      "type": "timeseries",
      "title": "Backtest Max Drawdown %",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "ai_backtest_max_drawdown_pct",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      }
    },
    {
      "type": "timeseries",
      "title": "Backtest Duration Quantiles",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, rate(ai_backtest_duration_seconds_bucket[15m]))",
          "refId": "Median"
        },
        {
          "expr": "histogram_quantile(0.9, rate(ai_backtest_duration_seconds_bucket[15m]))",
          "refId": "P90"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 14
      }
    },
    {
      "type": "table",
      "title": "Latest Backtest Completion",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "ai_backtest_last_completed_timestamp",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 14
      }
    },
    {
      "type": "timeseries",
      "title": "Backtest Total PnL (Postgres)",
      "datasource": {
        "type": "postgres",
        "uid": "postgres"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT\n    completed_at AS \"time\",\n    run_name AS metric,\n    total_pnl AS value\nFROM ai_extensions.v_backtest_performance\nWHERE completed_at IS NOT NULL\nORDER BY completed_at;"
        }
      ],
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 22
      }
    },
    {
      "type": "table",
      "title": "Latest Run Snapshot (Postgres)",
      "datasource": {
        "type": "postgres",
        "uid": "postgres"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT\n    run_name,\n    instrument_id,\n    total_trades,\n    total_pnl,\n    total_pnl_pct,\n    sharpe_ratio,\n    profit_factor,\n    calculated_win_rate,\n    completed_at\nFROM ai_extensions.v_backtest_performance\nORDER BY completed_at DESC\nLIMIT 5;"
        }
      ],
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 22
      }
    },
    {
      "type": "table",
      "title": "Strategy Comparison (Postgres)",
      "datasource": {
        "type": "postgres",
        "uid": "postgres"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT\n    strategy_id,\n    instrument_id,\n    runs,\n    avg_total_pnl,\n    avg_total_pnl_pct,\n    avg_sharpe_ratio,\n    avg_drawdown_pct,\n    avg_profit_factor,\n    avg_win_rate,\n    last_completed_at\nFROM ai_extensions.v_strategy_comparison\nORDER BY last_completed_at DESC NULLS LAST;"
        }
      ],
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 32
      }
    },
    {
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "last"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      },
